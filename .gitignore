# ============================================
# 东方白鹳 - Git忽略文件
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# 日志
logs/
*.log

# 数据库
*.sqlite3
*.db

# 测试覆盖率
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
.nox/

# 文档构建
docs/_build/
site/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 构建输出
frontend/*/dist/
frontend/*/build/
*.tsbuildinfo

# Docker
.dockerignore

# 临时文件
tmp/
temp/
*.tmp

# 系统文件
Thumbs.db
.DS_Store

# 敏感文件
*.pem
*.key
*.crt
secrets/

# 数据文件
data/*.json
data/*.csv
!data/.gitkeep

# 上传文件
uploads/
media/

# 备份文件
*.bak
*.backup
